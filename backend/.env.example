# Comma-separated list, example:
# CORS_ORIGINS=https://your-frontend.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Set true only for quick debugging
CORS_ALLOW_ALL=false

# Development (Windows):
# DJI_IRP_PATH=C:\path\to\dji_irp.exe
# Production (Linux / Render):
# DJI_IRP_PATH=/app/tools/dji-tsdk/utility/bin/linux/release_x64/dji_irp
# LD_LIBRARY_PATH=/app/tools/dji-tsdk/utility/bin/linux/release_x64
YOLO_DEVICE=cpu
HOTSPOT_MODEL_PATH=
EQUIPMENT_MODEL_PATH=
HOTSPOT_CONFIDENCE=0.2
HOTSPOT_IOU=0.5
EQUIPMENT_CONFIDENCE=0.2
EQUIPMENT_IOU=0.5
THERMAL_CENTER_SHIFT_X=-10
THERMAL_CENTER_SHIFT_Y=-1
EQUIPMENT_BBOX_DILATION=12
MATCH_DISTANCE_THRESHOLD=40
REFERENCE_TEMP_MAX_C=28
RGB_DETECTION_MAX_DIM=1600
TORCH_NUM_THREADS=1
TORCH_INTEROP_THREADS=1
EXIFTOOL_PATH=
DJI_IRP_PATH=
